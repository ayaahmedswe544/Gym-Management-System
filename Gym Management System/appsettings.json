{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=RUE-LAP\\SQLEXPRESS;Database=GymSystem;Integrated Security=True;Trust Server Certificate=True;"
  },
  "Jwt": {
    "Key": "this-is-the-secret-key-that-must-be-at-least-32-characters-long-for-development",
    "Issuer": "GymManagementAPI",
    "Audience": "GymManagementUsers"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "./Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
